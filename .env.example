# ==============================================================================
# CONFIGURACIÓN DE ESCALADO DE LA API (HIGH TRAFFIC LIGHT)
# ==============================================================================

# Límites de Réplicas del Backend
API_REPLICAS_MIN=5
API_REPLICAS_MAX=15

# Políticas del Autoscaler
SCALE_UP_BY=2        # Réplicas a añadir por evento de scale-up
SCALE_DOWN_BY=1      # Réplicas a remover por evento de scale-down
SCALE_COOLDOWN=120   # Segundos de espera entre operaciones de escalado
